# PostHog Analytics
NEXT_PUBLIC_POSTHOG_KEY=phc_your_posthog_api_key_here
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Database — MongoDB Atlas connection string (include a db name before the "?")
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/devevents?appName=YourApp

# Redis — Upstash REST (recommended for serverless/Vercel). From the Upstash
# console → your database → "REST" connect tab. Without these the app falls
# back to an in-memory store (fine for local dev, not for production).
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_rest_token

# Base URLs
NEXT_PUBLIC_BASE_URL=https://devevents.dev
NEXT_PUBLIC_APP_URL=https://devevents.dev

# Auth — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-random-secret-minimum-32-chars
NEXTAUTH_URL=https://devevents.dev
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret

# Email (Resend)
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=noreply@yourdomain.com
RESEND_FROM_NAME=DevEvents

# Stripe — get from dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret
STRIPE_CONNECT_CLIENT_ID=ca_your_stripe_connect_client_id

# Cloudinary
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# Platform Fee Configuration
PLATFORM_FEE_RATE_FREE=0.05
PLATFORM_FEE_RATE_PRO=0.03
PLATFORM_FEE_FIXED_FREE_MINOR=0
PLATFORM_FEE_FIXED_PRO_MINOR=0
PROCESSOR_FEE_ESTIMATE_RATE=0.029
PROCESSOR_FEE_ESTIMATE_FIXED_MINOR=30
NEXT_PUBLIC_PLATFORM_FEE_PREVIEW_RATE=0.05
NEXT_PUBLIC_PLATFORM_FEE_PREVIEW_FIXED_MINOR=0

# Security
CRON_SECRET=your-cron-secret-minimum-32-chars
CHECKOUT_RATE_LIMIT_PER_IP=10

# Error monitoring (optional — Sentry is inert without these)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Razorpay — get from dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
